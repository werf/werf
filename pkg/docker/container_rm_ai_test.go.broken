func TestAI_Rm_NotFound(t *testing.T) {
	ctx := context.Background()
	err := Init(ctx, InitOptions{})
	require.NoError(t, err)

	err = CliRm(ctx, "nonexistent-container-12345")
	assert.Error(t, err)
}

func TestAI_Rm_RecordedOutput_Success(t *testing.T) {
	ctx := context.Background()
	err := Init(ctx, InitOptions{})
	require.NoError(t, err)

	pullResp, err := apiCli(ctx).ImagePull(ctx, "alpine:latest", image.PullOptions{})
	require.NoError(t, err)
	_, _ = io.Copy(io.Discard, pullResp)
	_ = pullResp.Close()

	createResp, err := apiCli(ctx).ContainerCreate(ctx, &container.Config{
		Image: "alpine:latest",
		Cmd:   []string{"true"},
	}, nil, nil, nil, "")
	require.NoError(t, err)
	containerID := createResp.ID

	output, err := CliRm_RecordedOutput(ctx, containerID)
	assert.NoError(t, err)
	assert.Equal(t, "", output)

	_, err = ContainerInspect(ctx, containerID)
	assert.Error(t, err)
}

